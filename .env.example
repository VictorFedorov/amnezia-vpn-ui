# Database configuration
DATABASE_URL=sqlite:///./vpn_manager.db
# For PostgreSQL in production:
# DATABASE_URL=postgresql://user:password@localhost/vpn_manager

# SSH configuration for VPS servers (per-server credentials are stored in DB)
SSH_HOST=your_vps_ip
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=
# SSH_KEY_PATH=/path/to/private/key

# JWT configuration
# IMPORTANT: Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30 days

# Encryption key for SSH passwords stored in DB (Fernet)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# CORS configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Traffic monitoring configuration
TRAFFIC_POLL_INTERVAL=300  # seconds (5 minutes)
SUBSCRIPTION_CHECK_INTERVAL=3600  # seconds (1 hour)

# Admin account (created on first startup)
ADMIN_USERNAME=admin
# ADMIN_PASSWORD=  # Leave unset for auto-generated password (shown in logs once)
